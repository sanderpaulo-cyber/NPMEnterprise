# Arranque (Windows): se o PowerShell disser que 'pnpm' nao existe, use:
#   npm run dev
#   npm run ports:check
# Opcional:  corepack enable   (reabra o terminal) para passar a ter pnpm via corepack.
#
# PostgreSQL (obrigatorio para a API; sem isto o dev encerra ao falhar o bootstrap)
# Com Docker: npm run docker:postgres   depois: npm run db:push
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/networksentinel

# API
API_PORT=8080
LOG_LEVEL=info
PGPOOL_MAX=20
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECT_TIMEOUT_MS=10000

# Dashboard — porta 443 (Windows: executar terminal como Administrador, ou use WEB_PORT=8443)
# HTTPS: WEB_HTTPS=1 (cert em memoria via Vite) OU ficheiros PEM:
#   pnpm cert:localhost  →  WEB_SSL_KEY / WEB_SSL_CERT como abaixo
# HTTP na 443 (sem TLS): WEB_HTTPS=0  →  abra http://localhost/ (navegador pode avisar)
WEB_PORT=443
WEB_HTTPS=1
# WEB_SSL_KEY=.local/certs/localhost-key.pem
# WEB_SSL_CERT=.local/certs/localhost-cert.pem
API_PROXY_TARGET=http://127.0.0.1:8080
BASE_PATH=/

# Autenticacao (JWT + utilizadores em auth_users)
# Passos: (1) npm run db:push  (2) AUTH_ENABLED=true + AUTH_JWT_SECRET (>=16 chars)
#         (3) primeiro user (tabela auth_users vazia):
#             - sem AUTH_BOOTSTRAP_* → admin / ChangeMeAdmin2026! (altere ja apos login)
#             - ou defina AUTH_BOOTSTRAP_USERNAME / AUTH_BOOTSTRAP_PASSWORD abaixo
#             - ou: npm run auth:create-user -- admin SuaPasswordForte
# Limpar todos os utilizadores e recriar so admin (senha predefinida ou AUTH_RESET_ADMIN_PASSWORD):
#   npm run auth:reset
# Opcional: AUTH_RESET_ADMIN_USERNAME=admin
#           AUTH_RESET_ADMIN_PASSWORD=ChangeMeAdmin2026!
#         (4) reinicie a API
# AUTH_ENABLED=false mantem API aberta. Com true: protege /api/* exceto health e /api/auth/*.
AUTH_ENABLED=false
# Obrigatorio se AUTH_ENABLED=true (minimo 16 caracteres):
# AUTH_JWT_SECRET=altere-este-segredo-longo-e-aleatorio
# AUTH_TOKEN_EXPIRY_HOURS=12
# Primeiro utilizador local (ignorado se ja existir algum em auth_users).
# Se omitir as duas linhas, a API cria admin / ChangeMeAdmin2026! na primeira subida.
# Password custom: minimo 10 caracteres e 3 classes (minusc./maiusc./digitos/simbolos)
# AUTH_BOOTSTRAP_USERNAME=admin
# AUTH_BOOTSTRAP_PASSWORD=AltereEstaPassword123
# Registo na pagina /login (alem do bootstrap):
# AUTH_ALLOW_REGISTER=false
# JWT: issuer/audience (tokens antigos sem estes claims deixam de ser validos)
# AUTH_JWT_ISSUER=networksentinel
# AUTH_JWT_AUDIENCE=npm-dashboard
# Sessao dashboard: cookie HttpOnly ns_session (Bearer opcional com AUTH_LOGIN_BODY_TOKEN=true)
# AUTH_LOGIN_BODY_TOKEN=false
# Cookie Secure: auto com HTTPS / X-Forwarded-Proto; forcado: AUTH_COOKIE_SECURE=true|false
# Atras de proxy: numero de hops (0 = desligado)
# TRUST_PROXY=1
# LDAP (opcional): apos falha de password local, tenta bind LDAP e cria/atualiza utilizador
# AUTH_LDAP_URL=ldap://seu-dc:389
# AUTH_LDAP_USER_DN_TEMPLATE=uid={{username}},ou=users,dc=example,dc=com
# Futuro: OAuth2 / SAML — ver GET /api/auth/providers

# Data mode
ENABLE_DEMO_SEED=false
NETWORK_POLLING_MODE=icmp
NETWORK_POLL_INTERVAL_MS=30000
NETWORK_POLL_BATCH_SIZE=6
NETWORK_DETAILED_POLL_INTERVAL_MS=300000
DISCOVERY_MAX_PARALLEL_RUNS=1
DISCOVERY_API_RATE_LIMIT_WINDOW_MS=60000
DISCOVERY_API_RATE_LIMIT_MAX=10

# Discovery tuning
DISCOVERY_MAX_HOSTS_PER_RUN=512
DISCOVERY_HOST_CONCURRENCY=6

# Optional direct frontend API override
# VITE_API_BASE_URL=
